{
    "name": "craftide",
    "version": "0.2.15",
    "description": "CraftIDE - Minecraft Development Studio: AI-powered IDE for Minecraft plugin and Skript development",
    "author": "Ali975",
    "license": "AGPL-3.0-only",
    "repository": {
        "type": "git",
        "url": "https://github.com/ali975/CraftIDE-MyFirstProject.git"
    },
    "bugs": {
        "url": "https://github.com/ali975/CraftIDE-MyFirstProject/issues"
    },
    "homepage": "https://github.com/ali975/CraftIDE-MyFirstProject#readme",
    "main": "dist/main/main.js",
    "scripts": {
        "start": "electron .",
        "dev": "npm run build:main && electron .",
        "build:main": "tsc -p tsconfig.main.json",
        "test": "node scripts/run-node-tests.js",
        "i18n:audit": "node scripts/i18n-audit.js",
        "dist": "npm run build:main && electron-builder --win",
        "dist:publish": "npm run build:main && electron-builder --win --publish always",
        "postdist": "node scripts/generate-release-checksums.js",
        "release:prep": "node scripts/release-prep.js",
        "dist:portable": "npm run build:main && electron-builder --win portable",
        "pack": "npm run build:main && electron-builder --dir"
    },
    "build": {
        "appId": "com.craftide.app",
        "productName": "CraftIDE",
        "directories": {
            "output": "release"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "ali975",
                "repo": "CraftIDE-MyFirstProject",
                "releaseType": "release"
            }
        ],
        "files": [
            "dist/main/**/*",
            "src/renderer/**/*",
            "src/shared/**/*",
            "logo.png",
            "assets/icons/**/*",
            "node_modules/**/*"
        ],
        "forceCodeSigning": false,
        "win": {
            "icon": "assets/icons/craftide.ico",
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "artifactName": "${productName}-${version}.${ext}",
            "signAndEditExecutable": false
        },
        "portable": {
            "artifactName": "${productName}-${version}.${ext}"
        },
        "nsis": {
            "artifactName": "${productName}-Setup-${version}.${ext}",
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "assets/icons/craftide.ico",
            "uninstallerIcon": "assets/icons/craftide.ico",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "CraftIDE"
        }
    },
    "dependencies": {
        "electron-updater": "^6.8.3",
        "monaco-editor": "^0.45.0",
        "xterm": "^5.3.0",
        "xterm-addon-fit": "^0.8.0"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "electron": "^28.1.0",
        "electron-builder": "^24.9.1",
        "typescript": "^5.3.3"
    }
}
