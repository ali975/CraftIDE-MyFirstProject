{
    "name": "Skript",
    "scopeName": "source.skript",
    "fileTypes": [
        "sk"
    ],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#options"
        },
        {
            "include": "#commands"
        },
        {
            "include": "#events"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#conditions"
        },
        {
            "include": "#effects"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#types"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.skript",
                    "match": "#.*$"
                }
            ]
        },
        "options": {
            "patterns": [
                {
                    "name": "meta.options.skript",
                    "match": "^(options)\\s*:",
                    "captures": {
                        "1": {
                            "name": "keyword.control.options.skript"
                        }
                    }
                },
                {
                    "name": "variable.other.option.skript",
                    "match": "\\{@[\\w-]+\\}"
                }
            ]
        },
        "commands": {
            "patterns": [
                {
                    "name": "meta.command.skript",
                    "match": "^(command)\\s+(/\\S+)\\s*:",
                    "captures": {
                        "1": {
                            "name": "keyword.control.command.skript"
                        },
                        "2": {
                            "name": "entity.name.function.command.skript"
                        }
                    }
                },
                {
                    "name": "keyword.other.command-property.skript",
                    "match": "^\\s+(trigger|permission|description|usage|aliases|executable by|cooldown|permission message|prefix)\\s*:"
                }
            ]
        },
        "events": {
            "patterns": [
                {
                    "name": "meta.event.skript",
                    "match": "^(on)\\s+(.+?)\\s*:",
                    "captures": {
                        "1": {
                            "name": "keyword.control.event.skript"
                        },
                        "2": {
                            "name": "entity.name.type.event.skript"
                        }
                    }
                },
                {
                    "name": "meta.event.skript",
                    "match": "^(every)\\s+(.+?)\\s*:",
                    "captures": {
                        "1": {
                            "name": "keyword.control.event.skript"
                        },
                        "2": {
                            "name": "entity.name.type.event.skript"
                        }
                    }
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "meta.function-definition.skript",
                    "match": "^(function)\\s+(\\w+)\\((.*)\\)\\s*(::.*)?\\s*:",
                    "captures": {
                        "1": {
                            "name": "keyword.control.function.skript"
                        },
                        "2": {
                            "name": "entity.name.function.skript"
                        },
                        "3": {
                            "name": "variable.parameter.skript"
                        },
                        "4": {
                            "name": "storage.type.return.skript"
                        }
                    }
                }
            ]
        },
        "conditions": {
            "patterns": [
                {
                    "name": "keyword.control.conditional.skript",
                    "match": "\\b(if|else if|else|then)\\b"
                },
                {
                    "name": "keyword.control.loop.skript",
                    "match": "\\b(loop|while|loop-value|loop-index|loop-player|loop-number)\\b"
                },
                {
                    "name": "keyword.control.flow.skript",
                    "match": "\\b(stop|exit|return|continue)\\b"
                }
            ]
        },
        "effects": {
            "patterns": [
                {
                    "name": "keyword.other.effect.skript",
                    "match": "\\b(send|broadcast|message|set|add|remove|delete|clear|kill|teleport|give|execute|wait|cancel event|cancel|make|spawn|play|strike lightning|create|open|close|ban|unban|kick|op|deop|heal|feed|damage|enchant|apply|charge|launch|push|pull|equip)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.skript",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.skript",
                            "match": "%%|%[^%]+%"
                        },
                        {
                            "name": "constant.other.color-code.skript",
                            "match": "&[0-9a-fk-or]"
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.skript",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.global.skript",
                    "match": "\\{[^}]+\\}"
                },
                {
                    "name": "variable.language.skript",
                    "match": "\\b(player|victim|attacker|event-player|event-block|event-entity|shooter|target|console|sender|world|location|block|tool|item|projectile|loop-value|loop-player|loop-number|arg[- ]?\\d*|arg[ument]?[- ]?\\d*)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.skript",
                    "match": "\\b(text|string|number|integer|boolean|player|entity|block|item|itemtype|location|world|inventory|slot|enchantment|potion|biome|gamemode|weather|time|timespan|date|color|direction|vector|chunk|region|money|experience|level)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.other.skript",
                    "match": "\\b(is|are|isn't|aren't|was|were|will be|not|true|false|yes|no|on|off|none|null|air|and|or|nor|but|to|from|in|at|with|without|of|as|for|between|has|have|doesn't have|does not have|contains|doesn't contain|does not contain|is set|is not set|isn't set|exists|doesn't exist|does not exist|can|cannot|can't)\\b"
                },
                {
                    "name": "constant.language.skript",
                    "match": "\\b(true|false|yes|no|on|off|none|null|air)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.skript",
                    "match": "(\\+|-|\\*|/|\\^|>=|<=|>|<|=|!=|is equal to|is not equal to|is greater than|is less than)"
                }
            ]
        }
    }
}