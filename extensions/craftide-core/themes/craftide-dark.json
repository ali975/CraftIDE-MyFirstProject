    "tokenColors": [
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#636e72",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Keywords",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.new",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#1abc9c"
            }
        },
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.quoted",
                "punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#2ecc71"
            }
        },
        {
            "name": "Numbers",
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#f39c12"
            }
        },
        {
            "name": "Constants",
            "scope": [
                "constant",
                "constant.language",
                "variable.language"
            ],
            "settings": {
                "foreground": "#e74c3c"
            }
        },
        {
            "name": "Functions",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call"
            ],
            "settings": {
                "foreground": "#3498db"
            }
        },
        {
            "name": "Classes & Types",
            "scope": [
                "entity.name.class",
                "entity.name.type",
                "support.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#f39c12",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Interfaces & Type Parameters",
            "scope": [
                "entity.name.type.interface",
                "entity.name.type.parameter"
            ],
            "settings": {
                "foreground": "#9b59b6",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Variables & Parameters",
            "scope": [
                "variable",
                "variable.parameter",
                "variable.other"
            ],
            "settings": {
                "foreground": "#dfe6e9"
            }
        },
        {
            "name": "Properties",
            "scope": [
                "variable.other.property",
                "support.variable.property"
            ],
            "settings": {
                "foreground": "#b2bec3"
            }
        },
        {
            "name": "Annotations & Decorators",
            "scope": [
                "meta.decorator",
                "storage.type.annotation",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#e74c3c",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Operators",
            "scope": [
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#1abc9c"
            }
        },
        {
            "name": "Punctuation",
            "scope": [
                "punctuation"
            ],
            "settings": {
                "foreground": "#b2bec3"
            }
        },
        {
            "name": "Import/Package",
            "scope": [
                "keyword.other.import",
                "keyword.other.package",
                "storage.modifier.import",
                "storage.modifier.package"
            ],
            "settings": {
                "foreground": "#6c3483"
            }
        },
        {
            "name": "Escape Characters",
            "scope": [
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#e74c3c"
            }
        },
        {
            "name": "Invalid / Deprecated",
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#636e72",
                "fontStyle": "strikethrough"
            }
        },
        {
            "name": "YAML Keys",
            "scope": [
                "entity.name.tag.yaml"
            ],
            "settings": {
                "foreground": "#1abc9c"
            }
        },
        {
            "name": "YAML Values",
            "scope": [
                "string.unquoted.plain.out.yaml"
            ],
            "settings": {
                "foreground": "#2ecc71"
            }
        },
        {
            "name": "XML Tags",
            "scope": [
                "entity.name.tag.xml",
                "entity.name.tag.html"
            ],
            "settings": {
                "foreground": "#e74c3c"
            }
        },
        {
            "name": "XML Attributes",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#f39c12",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markdown Headings",
            "scope": [
                "markup.heading",
                "entity.name.section"
            ],
            "settings": {
                "foreground": "#2ecc71",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markdown Bold",
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#f39c12",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markdown Links",
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#3498db"
            }
        }
    ],
    "semanticTokenColors": {
        "class": "#f39c12",
        "interface": "#9b59b6",
        "enum": "#e74c3c",
        "function": "#3498db",
        "method": "#3498db",
        "property": "#b2bec3",
        "variable": "#dfe6e9",
        "parameter": "#dfe6e9",
        "type": "#f39c12",
        "namespace": "#6c3483",
        "enumMember": "#e74c3c",
        "annotation": {
            "foreground": "#e74c3c",
            "italic": true
        }
    }
}